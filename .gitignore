__pycache__/
*.py[cod]
ftjob_generated_*.py
ftjob_generated_*.pkl
# radas cluster packaging needs these temporary files visible to Ray.
# Keep them out of commits by moving/removing them after submission.
!ftjob_generated_entry_point_*.py
!ftjob_generated_meta_config_*.pkl
!ftjob_generated_param_space_*.pkl

# Local datasets and generated artifacts from legacy experiment scripts.
data/
logs/
png/
g=*/
g(x)=*/

# Keep comparable minimal-suite results versionable after materialization.
experiments/minimal_suite/results/*
!experiments/minimal_suite/results/*.csv
!experiments/minimal_suite/results/*.md
!experiments/minimal_suite/results/*.json
experiments/dthreeq_suite/results/*
!experiments/dthreeq_suite/results/*.csv
!experiments/dthreeq_suite/results/*.md
!experiments/dthreeq_suite/results/*.json
!experiments/dthreeq_suite/results/*.png
